<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
	xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
	xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
	xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
	xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	id="Definitions_Egensotning"
	targetNamespace="http://bpmn.io/schema/bpmn">

	<!-- Message declarations -->
	<bpmn:message id="Message_KompletteringMottagen" name="komplettering-received" />
	<bpmn:message id="Message_ManualReviewCompleted" name="manual-review-completed" />

	<bpmn:process id="egensotning-process" name="Hantera ansökan om egensotning" isExecutable="true" camunda:historyTimeToLive="P30D">

		<!-- ============================================================
		     START → automated verification
		     ============================================================ -->
		<bpmn:startEvent id="AnsokanMottagen" name="Ansökan mottagen">
			<bpmn:outgoing>Flow_Start_Verifiera</bpmn:outgoing>
		</bpmn:startEvent>
		<bpmn:sequenceFlow id="Flow_Start_Verifiera" sourceRef="AnsokanMottagen" targetRef="VerifieraAnsokan" />

		<!-- Runs the three automated checks (bilaga present, folkbokförd at the
		     property, återansökan status) in rtj-management and writes the routing
		     outcome to process variables. Re-entered after a komplettering. -->
		<bpmn:serviceTask id="VerifieraAnsokan" name="Verifiera ansökan" camunda:type="external" camunda:topic="rtj-verify-egensotning">
			<bpmn:incoming>Flow_Start_Verifiera</bpmn:incoming>
			<bpmn:incoming>Flow_Komplettering_ReVerifiera</bpmn:incoming>
			<bpmn:outgoing>Flow_Verifiera_Gateway</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_Verifiera_Gateway" sourceRef="VerifieraAnsokan" targetRef="Gateway_Outcome" />

		<bpmn:exclusiveGateway id="Gateway_Outcome" name="Utfall?" default="Flow_Outcome_Manuell">
			<bpmn:incoming>Flow_Verifiera_Gateway</bpmn:incoming>
			<bpmn:outgoing>Flow_Outcome_AutoGodkann</bpmn:outgoing>
			<bpmn:outgoing>Flow_Outcome_Komplettering</bpmn:outgoing>
			<bpmn:outgoing>Flow_Outcome_Manuell</bpmn:outgoing>
		</bpmn:exclusiveGateway>

		<bpmn:sequenceFlow id="Flow_Outcome_AutoGodkann" sourceRef="Gateway_Outcome" targetRef="SkapaBeslut">
			<bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${outcome == 'AUTO_APPROVE'}</bpmn:conditionExpression>
		</bpmn:sequenceFlow>
		<bpmn:sequenceFlow id="Flow_Outcome_Komplettering" sourceRef="Gateway_Outcome" targetRef="SattStatusAwaitingSupplementation">
			<bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${outcome == 'NEEDS_SUPPLEMENT'}</bpmn:conditionExpression>
		</bpmn:sequenceFlow>
		<bpmn:sequenceFlow id="Flow_Outcome_Manuell" sourceRef="Gateway_Outcome" targetRef="MeddelaBSK" />

		<!-- ============================================================
		     APPROVE PATH — create decision, email, set status, end.
		     Shared by the auto-approve and the manual-approve branches.
		     ============================================================ -->
		<bpmn:serviceTask id="SkapaBeslut" name="Skapa beslut (godkänn)" camunda:type="external" camunda:topic="rtj-add-errand-decision">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="decisionType">APPROVAL</camunda:inputParameter>
					<camunda:inputParameter name="value">APPROVED</camunda:inputParameter>
					<!-- Formell beslutstext genereras av verifieringssteget från sotningsobjekt + lagstöd/villkor/överklagande -->
					<camunda:inputParameter name="description">${decisionDescription}</camunda:inputParameter>
					<camunda:inputParameter name="createdBy">SYSTEM</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_Outcome_AutoGodkann</bpmn:incoming>
			<bpmn:incoming>Flow_Manuell_Godkann</bpmn:incoming>
			<bpmn:outgoing>Flow_SkapaBeslut_MailaBeslut</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_SkapaBeslut_MailaBeslut" sourceRef="SkapaBeslut" targetRef="MailaBeslut" />

		<bpmn:serviceTask id="MailaBeslut" name="Maila beslut till berörd" camunda:type="external" camunda:topic="send-email">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="emailAddress">${applicantEmail}</camunda:inputParameter>
					<camunda:inputParameter name="subject">Beslut: Ansökan om egensotning godkänd</camunda:inputParameter>
					<camunda:inputParameter name="message">Hej, din ansökan om egensotning har godkänts med stöd av 3 kap. 4 § lagen (2003:778) om skydd mot olyckor. Villkor: (1) medgivandet gäller tillsvidare men kan återkallas om brandskyddskontroll visar brister, (2) utförda sotningar ska dokumenteras i en särskild liggare som kan visas vid brandskyddskontroll, (3) medgivandet upphör automatiskt vid ägarbyte. Du kan överklaga beslutet skriftligt till Länsstyrelsen i Västernorrlands län inom tre (3) veckor från den dag du tog del av det; överklagandet skickas till Medelpads Räddningstjänstförbund. Fullständigt beslut finns på Mina sidor.</camunda:inputParameter>
					<camunda:inputParameter name="senderName">Räddningstjänsten Medelpad</camunda:inputParameter>
					<camunda:inputParameter name="senderAddress">noreply@sundsvall.se</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_SkapaBeslut_MailaBeslut</bpmn:incoming>
			<bpmn:outgoing>Flow_MailaBeslut_SattStatus</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_MailaBeslut_SattStatus" sourceRef="MailaBeslut" targetRef="SattStatusGodkand" />

		<bpmn:serviceTask id="SattStatusGodkand" name="Sätt status: beslut taget" camunda:type="external" camunda:topic="rtj-update-errand">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="status">DECIDED</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_MailaBeslut_SattStatus</bpmn:incoming>
			<bpmn:outgoing>Flow_SattStatus_BeslutTaget</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_SattStatus_BeslutTaget" sourceRef="SattStatusGodkand" targetRef="BeslutTaget" />

		<bpmn:endEvent id="BeslutTaget" name="Ansökan godkänns">
			<bpmn:incoming>Flow_SattStatus_BeslutTaget</bpmn:incoming>
		</bpmn:endEvent>

		<!-- ============================================================
		     KOMPLETTERING (bilaga saknas) — set status, email, wait for the
		     applicant to supplement, then RE-RUN the checks.
		     ============================================================ -->
		<bpmn:serviceTask id="SattStatusAwaitingSupplementation" name="Sätt status: inväntar komplettering" camunda:type="external" camunda:topic="rtj-update-errand">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="status">AWAITING_SUPPLEMENTATION</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_Outcome_Komplettering</bpmn:incoming>
			<bpmn:outgoing>Flow_AwaitingStatus_BegarKomplettering</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_AwaitingStatus_BegarKomplettering" sourceRef="SattStatusAwaitingSupplementation" targetRef="BegarKomplettering" />

		<bpmn:serviceTask id="BegarKomplettering" name="Kontakta berörd, begär komplettering" camunda:type="external" camunda:topic="send-email">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="emailAddress">${applicantEmail}</camunda:inputParameter>
					<camunda:inputParameter name="subject">Komplettering behövs för din ansökan om egensotning</camunda:inputParameter>
					<camunda:inputParameter name="message">Hej, vi behöver komplettera din ansökan om egensotning (t.ex. en bilaga eller uppgifter om sotningsobjekt). Vänligen logga in på Mina sidor och komplettera.</camunda:inputParameter>
					<camunda:inputParameter name="senderName">Räddningstjänsten Medelpad</camunda:inputParameter>
					<camunda:inputParameter name="senderAddress">noreply@sundsvall.se</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_AwaitingStatus_BegarKomplettering</bpmn:incoming>
			<bpmn:outgoing>Flow_BegarKomplettering_Vanta</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_BegarKomplettering_Vanta" sourceRef="BegarKomplettering" targetRef="KompletteringMottagen" />

		<!-- Pauses until POST /process-messages correlates "komplettering-received".
		     The applicant has added the bilaga; loop back to re-verify. -->
		<bpmn:intermediateCatchEvent id="KompletteringMottagen" name="Komplettering mottagen">
			<bpmn:incoming>Flow_BegarKomplettering_Vanta</bpmn:incoming>
			<bpmn:outgoing>Flow_Komplettering_ReVerifiera</bpmn:outgoing>
			<bpmn:messageEventDefinition messageRef="Message_KompletteringMottagen" />
		</bpmn:intermediateCatchEvent>
		<bpmn:sequenceFlow id="Flow_Komplettering_ReVerifiera" sourceRef="KompletteringMottagen" targetRef="VerifieraAnsokan" />

		<!-- ============================================================
		     MANUAL REVIEW — assign BSK, set status, wait for the handläggare to
		     approve/reject via rtj-management (manual-review-completed message).
		     ============================================================ -->
		<bpmn:serviceTask id="MeddelaBSK" name="Meddela BSK" camunda:type="external" camunda:topic="rtj-notify-bsk">
			<bpmn:incoming>Flow_Outcome_Manuell</bpmn:incoming>
			<bpmn:outgoing>Flow_MeddelaBSK_SattStatusManuell</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_MeddelaBSK_SattStatusManuell" sourceRef="MeddelaBSK" targetRef="SattStatusManuell" />

		<bpmn:serviceTask id="SattStatusManuell" name="Sätt status: manuell granskning" camunda:type="external" camunda:topic="rtj-update-errand">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="status">UNDER_MANUAL_REVIEW</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_MeddelaBSK_SattStatusManuell</bpmn:incoming>
			<bpmn:outgoing>Flow_SattStatusManuell_Vanta</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_SattStatusManuell_Vanta" sourceRef="SattStatusManuell" targetRef="ManuellGranskning" />

		<!-- Pauses until POST /process-messages correlates "manual-review-completed"
		     with manuelltGodkand=true|false (the handläggare's decision in the UI). -->
		<bpmn:intermediateCatchEvent id="ManuellGranskning" name="Manuell granskning klar">
			<bpmn:incoming>Flow_SattStatusManuell_Vanta</bpmn:incoming>
			<bpmn:outgoing>Flow_ManuellGranskning_Gateway</bpmn:outgoing>
			<bpmn:messageEventDefinition messageRef="Message_ManualReviewCompleted" />
		</bpmn:intermediateCatchEvent>
		<bpmn:sequenceFlow id="Flow_ManuellGranskning_Gateway" sourceRef="ManuellGranskning" targetRef="Gateway_Manuell" />

		<bpmn:exclusiveGateway id="Gateway_Manuell" name="Godkänns?" default="Flow_Manuell_Avslag">
			<bpmn:incoming>Flow_ManuellGranskning_Gateway</bpmn:incoming>
			<bpmn:outgoing>Flow_Manuell_Godkann</bpmn:outgoing>
			<bpmn:outgoing>Flow_Manuell_Avslag</bpmn:outgoing>
		</bpmn:exclusiveGateway>

		<bpmn:sequenceFlow id="Flow_Manuell_Godkann" sourceRef="Gateway_Manuell" targetRef="SkapaBeslut">
			<bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${manuelltGodkand == true}</bpmn:conditionExpression>
		</bpmn:sequenceFlow>
		<bpmn:sequenceFlow id="Flow_Manuell_Avslag" sourceRef="Gateway_Manuell" targetRef="SkapaAvslag" />

		<bpmn:serviceTask id="SkapaAvslag" name="Skapa beslut (avslag)" camunda:type="external" camunda:topic="rtj-add-errand-decision">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="decisionType">REJECTION</camunda:inputParameter>
					<camunda:inputParameter name="value">REJECTED</camunda:inputParameter>
					<camunda:inputParameter name="description">Ansökan om egensotning avslagen efter manuell granskning. Beslut enligt 3 kap. 4 § lagen (2003:778) om skydd mot olyckor (LSO). Beslutet kan överklagas skriftligt till Länsstyrelsen i Västernorrlands län inom tre (3) veckor från delgivning; överklagandet skickas till Medelpads Räddningstjänstförbund.</camunda:inputParameter>
					<camunda:inputParameter name="createdBy">SYSTEM</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_Manuell_Avslag</bpmn:incoming>
			<bpmn:outgoing>Flow_SkapaAvslag_MailaAvslag</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_SkapaAvslag_MailaAvslag" sourceRef="SkapaAvslag" targetRef="MailaAvslag" />

		<bpmn:serviceTask id="MailaAvslag" name="Maila avslag till berörd" camunda:type="external" camunda:topic="send-email">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="emailAddress">${applicantEmail}</camunda:inputParameter>
					<camunda:inputParameter name="subject">Beslut: Avslag på ansökan om egensotning</camunda:inputParameter>
					<camunda:inputParameter name="message">Hej, efter granskning har din ansökan om egensotning avslagits. Beslutet är fattat med stöd av 3 kap. 4 § lagen (2003:778) om skydd mot olyckor. Du kan överklaga beslutet skriftligt till Länsstyrelsen i Västernorrlands län inom tre (3) veckor från den dag du tog del av det; överklagandet skickas till Medelpads Räddningstjänstförbund. Mer information finns på Mina sidor.</camunda:inputParameter>
					<camunda:inputParameter name="senderName">Räddningstjänsten Medelpad</camunda:inputParameter>
					<camunda:inputParameter name="senderAddress">noreply@sundsvall.se</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_SkapaAvslag_MailaAvslag</bpmn:incoming>
			<bpmn:outgoing>Flow_MailaAvslag_SattStatus</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_MailaAvslag_SattStatus" sourceRef="MailaAvslag" targetRef="SattStatusAvslag" />

		<bpmn:serviceTask id="SattStatusAvslag" name="Sätt status: avslag" camunda:type="external" camunda:topic="rtj-update-errand">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="status">REJECTED</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_MailaAvslag_SattStatus</bpmn:incoming>
			<bpmn:outgoing>Flow_SattStatusAvslag_Avslag</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_SattStatusAvslag_Avslag" sourceRef="SattStatusAvslag" targetRef="Avslag" />

		<bpmn:endEvent id="Avslag" name="Avslag">
			<bpmn:incoming>Flow_SattStatusAvslag_Avslag</bpmn:incoming>
		</bpmn:endEvent>

	</bpmn:process>

	<!-- ============================================================
	     DIAGRAM (DI) — row 1: verify + approve; row 2: komplettering loop;
	     row 3: manual review + reject. Layout is illustrative; re-layout in
	     the modeler if needed.
	     ============================================================ -->
	<bpmndi:BPMNDiagram id="BPMNDiagram_1">
		<bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="egensotning-process">

			<!-- ROW 1 (y≈200) -->
			<bpmndi:BPMNShape id="AnsokanMottagen_di" bpmnElement="AnsokanMottagen">
				<dc:Bounds x="152" y="182" width="36" height="36" />
			</bpmndi:BPMNShape>
			<bpmndi:BPMNShape id="VerifieraAnsokan_di" bpmnElement="VerifieraAnsokan">
				<dc:Bounds x="240" y="160" width="120" height="80" />
			</bpmndi:BPMNShape>
			<bpmndi:BPMNShape id="Gateway_Outcome_di" bpmnElement="Gateway_Outcome" isMarkerVisible="true">
				<dc:Bounds x="420" y="175" width="50" height="50" />
			</bpmndi:BPMNShape>
			<bpmndi:BPMNShape id="SkapaBeslut_di" bpmnElement="SkapaBeslut">
				<dc:Bounds x="530" y="160" width="120" height="80" />
			</bpmndi:BPMNShape>
			<bpmndi:BPMNShape id="MailaBeslut_di" bpmnElement="MailaBeslut">
				<dc:Bounds x="710" y="160" width="120" height="80" />
			</bpmndi:BPMNShape>
			<bpmndi:BPMNShape id="SattStatusGodkand_di" bpmnElement="SattStatusGodkand">
				<dc:Bounds x="890" y="160" width="120" height="80" />
			</bpmndi:BPMNShape>
			<bpmndi:BPMNShape id="BeslutTaget_di" bpmnElement="BeslutTaget">
				<dc:Bounds x="1070" y="182" width="36" height="36" />
			</bpmndi:BPMNShape>

			<!-- ROW 2 — komplettering (y≈340) -->
			<bpmndi:BPMNShape id="SattStatusAwaitingSupplementation_di" bpmnElement="SattStatusAwaitingSupplementation">
				<dc:Bounds x="400" y="300" width="120" height="80" />
			</bpmndi:BPMNShape>
			<bpmndi:BPMNShape id="BegarKomplettering_di" bpmnElement="BegarKomplettering">
				<dc:Bounds x="570" y="300" width="120" height="80" />
			</bpmndi:BPMNShape>
			<bpmndi:BPMNShape id="KompletteringMottagen_di" bpmnElement="KompletteringMottagen">
				<dc:Bounds x="740" y="322" width="36" height="36" />
			</bpmndi:BPMNShape>

			<!-- ROW 3 — manuell granskning + avslag (y≈480) -->
			<bpmndi:BPMNShape id="MeddelaBSK_di" bpmnElement="MeddelaBSK">
				<dc:Bounds x="400" y="440" width="120" height="80" />
			</bpmndi:BPMNShape>
			<bpmndi:BPMNShape id="SattStatusManuell_di" bpmnElement="SattStatusManuell">
				<dc:Bounds x="570" y="440" width="120" height="80" />
			</bpmndi:BPMNShape>
			<bpmndi:BPMNShape id="ManuellGranskning_di" bpmnElement="ManuellGranskning">
				<dc:Bounds x="740" y="462" width="36" height="36" />
			</bpmndi:BPMNShape>
			<bpmndi:BPMNShape id="Gateway_Manuell_di" bpmnElement="Gateway_Manuell" isMarkerVisible="true">
				<dc:Bounds x="830" y="455" width="50" height="50" />
			</bpmndi:BPMNShape>
			<bpmndi:BPMNShape id="SkapaAvslag_di" bpmnElement="SkapaAvslag">
				<dc:Bounds x="930" y="440" width="120" height="80" />
			</bpmndi:BPMNShape>
			<bpmndi:BPMNShape id="MailaAvslag_di" bpmnElement="MailaAvslag">
				<dc:Bounds x="1100" y="440" width="120" height="80" />
			</bpmndi:BPMNShape>
			<bpmndi:BPMNShape id="SattStatusAvslag_di" bpmnElement="SattStatusAvslag">
				<dc:Bounds x="1270" y="440" width="120" height="80" />
			</bpmndi:BPMNShape>
			<bpmndi:BPMNShape id="Avslag_di" bpmnElement="Avslag">
				<dc:Bounds x="1450" y="462" width="36" height="36" />
			</bpmndi:BPMNShape>

			<!-- ROW 1 edges -->
			<bpmndi:BPMNEdge id="Flow_Start_Verifiera_di" bpmnElement="Flow_Start_Verifiera">
				<di:waypoint x="188" y="200" /><di:waypoint x="240" y="200" />
			</bpmndi:BPMNEdge>
			<bpmndi:BPMNEdge id="Flow_Verifiera_Gateway_di" bpmnElement="Flow_Verifiera_Gateway">
				<di:waypoint x="360" y="200" /><di:waypoint x="420" y="200" />
			</bpmndi:BPMNEdge>
			<bpmndi:BPMNEdge id="Flow_Outcome_AutoGodkann_di" bpmnElement="Flow_Outcome_AutoGodkann">
				<di:waypoint x="470" y="200" /><di:waypoint x="530" y="200" />
			</bpmndi:BPMNEdge>
			<bpmndi:BPMNEdge id="Flow_SkapaBeslut_MailaBeslut_di" bpmnElement="Flow_SkapaBeslut_MailaBeslut">
				<di:waypoint x="650" y="200" /><di:waypoint x="710" y="200" />
			</bpmndi:BPMNEdge>
			<bpmndi:BPMNEdge id="Flow_MailaBeslut_SattStatus_di" bpmnElement="Flow_MailaBeslut_SattStatus">
				<di:waypoint x="830" y="200" /><di:waypoint x="890" y="200" />
			</bpmndi:BPMNEdge>
			<bpmndi:BPMNEdge id="Flow_SattStatus_BeslutTaget_di" bpmnElement="Flow_SattStatus_BeslutTaget">
				<di:waypoint x="1010" y="200" /><di:waypoint x="1070" y="200" />
			</bpmndi:BPMNEdge>

			<!-- ROW 2 edges (komplettering) -->
			<bpmndi:BPMNEdge id="Flow_Outcome_Komplettering_di" bpmnElement="Flow_Outcome_Komplettering">
				<di:waypoint x="445" y="225" /><di:waypoint x="445" y="300" />
			</bpmndi:BPMNEdge>
			<bpmndi:BPMNEdge id="Flow_AwaitingStatus_BegarKomplettering_di" bpmnElement="Flow_AwaitingStatus_BegarKomplettering">
				<di:waypoint x="520" y="340" /><di:waypoint x="570" y="340" />
			</bpmndi:BPMNEdge>
			<bpmndi:BPMNEdge id="Flow_BegarKomplettering_Vanta_di" bpmnElement="Flow_BegarKomplettering_Vanta">
				<di:waypoint x="690" y="340" /><di:waypoint x="740" y="340" />
			</bpmndi:BPMNEdge>
			<bpmndi:BPMNEdge id="Flow_Komplettering_ReVerifiera_di" bpmnElement="Flow_Komplettering_ReVerifiera">
				<di:waypoint x="758" y="322" /><di:waypoint x="758" y="262" /><di:waypoint x="300" y="262" /><di:waypoint x="300" y="240" />
			</bpmndi:BPMNEdge>

