<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
	xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
	xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
	xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
	xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	id="Definitions_Egensotning"
	targetNamespace="http://bpmn.io/schema/bpmn">

	<!-- Message declarations -->
	<bpmn:message id="Message_KompletteringMottagen" name="komplettering-received" />
	<bpmn:message id="Message_ManualReviewCompleted" name="manual-review-completed" />

	<bpmn:process id="egensotning-process" name="Hantera ansökan om egensotning" isExecutable="true" camunda:historyTimeToLive="P30D">

		<!-- ============================================================
		     START → automated verification
		     ============================================================ -->
		<bpmn:startEvent id="AnsokanMottagen" name="Ansökan mottagen">
			<bpmn:outgoing>Flow_Start_Verifiera</bpmn:outgoing>
		</bpmn:startEvent>
		<bpmn:sequenceFlow id="Flow_Start_Verifiera" sourceRef="AnsokanMottagen" targetRef="VerifieraAnsokan" />

		<!-- Runs the three automated checks (bilaga present, folkbokförd at the
		     property, återansökan status) in rtj-management and writes the routing
		     outcome to process variables. Re-entered after a komplettering. -->
		<bpmn:serviceTask id="VerifieraAnsokan" name="Verifiera ansökan" camunda:type="external" camunda:topic="rtj-verify-egensotning">
			<bpmn:incoming>Flow_Start_Verifiera</bpmn:incoming>
			<bpmn:incoming>Flow_Komplettering_ReVerifiera</bpmn:incoming>
			<bpmn:incoming>Flow_KomplManuell_ReVerifiera</bpmn:incoming>
			<bpmn:outgoing>Flow_Verifiera_Gateway</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_Verifiera_Gateway" sourceRef="VerifieraAnsokan" targetRef="Gateway_Outcome" />

		<bpmn:exclusiveGateway id="Gateway_Outcome" name="Utfall?" default="Flow_Outcome_Manuell">
			<bpmn:incoming>Flow_Verifiera_Gateway</bpmn:incoming>
			<bpmn:outgoing>Flow_Outcome_AutoGodkann</bpmn:outgoing>
			<bpmn:outgoing>Flow_Outcome_Komplettering</bpmn:outgoing>
			<bpmn:outgoing>Flow_Outcome_Manuell</bpmn:outgoing>
		</bpmn:exclusiveGateway>

		<bpmn:sequenceFlow id="Flow_Outcome_AutoGodkann" sourceRef="Gateway_Outcome" targetRef="ValideraDokument">
			<bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${outcome == 'AUTO_APPROVE'}</bpmn:conditionExpression>
		</bpmn:sequenceFlow>
		<bpmn:sequenceFlow id="Flow_Outcome_Komplettering" sourceRef="Gateway_Outcome" targetRef="SattStatusAwaitingSupplementation">
			<bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${outcome == 'NEEDS_SUPPLEMENT'}</bpmn:conditionExpression>
		</bpmn:sequenceFlow>
		<bpmn:sequenceFlow id="Flow_Outcome_Manuell" sourceRef="Gateway_Outcome" targetRef="SattStatusManuell" />

		<!-- ============================================================
		     DOCUMENT VALIDATION (Eneo/LLM) — only on the auto-approve branch, where both
		     bilagor are guaranteed present. Validates that the attachments are the right
		     document types, valid, and match the applicant. documentsValid==true continues
		     to the auto-approve decision; otherwise the errand is diverted to manual review
		     (the LLM never auto-rejects).
		     ============================================================ -->
		<bpmn:serviceTask id="ValideraDokument" name="Validera dokument (Eneo)" camunda:type="external" camunda:topic="rtj-validate-egensotning-documents">
			<bpmn:incoming>Flow_Outcome_AutoGodkann</bpmn:incoming>
			<bpmn:outgoing>Flow_Validera_Gateway</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_Validera_Gateway" sourceRef="ValideraDokument" targetRef="Gateway_DocumentValidation" />

		<bpmn:exclusiveGateway id="Gateway_DocumentValidation" name="Dokument giltiga?" default="Flow_DocInvalid_Manuell">
			<bpmn:incoming>Flow_Validera_Gateway</bpmn:incoming>
			<bpmn:outgoing>Flow_DocValid_SkapaBeslut</bpmn:outgoing>
			<bpmn:outgoing>Flow_DocInvalid_Manuell</bpmn:outgoing>
		</bpmn:exclusiveGateway>

		<bpmn:sequenceFlow id="Flow_DocValid_SkapaBeslut" sourceRef="Gateway_DocumentValidation" targetRef="SkapaBeslut">
			<bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${documentsValid == true}</bpmn:conditionExpression>
		</bpmn:sequenceFlow>
		<bpmn:sequenceFlow id="Flow_DocInvalid_Manuell" sourceRef="Gateway_DocumentValidation" targetRef="SattStatusManuell" />

		<!-- ============================================================
		     APPROVE PATH — create decision, set status (DECIDED), THEN email, end.
		     Status sätts FÖRE mailet så beslutet är definitivt även om mailleverans
		     fallerar (mailet är en notifiering, inte en del av själva beslutet).
		     Shared by the auto-approve and the manual-approve branches.
		     ============================================================ -->
		<bpmn:serviceTask id="SkapaBeslut" name="Skapa beslut (godkänn)" camunda:type="external" camunda:topic="rtj-add-errand-decision">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="decisionType">APPROVAL</camunda:inputParameter>
					<camunda:inputParameter name="value">APPROVED</camunda:inputParameter>
					<!-- Formell beslutstext genereras av verifieringssteget från sotningsobjekt + lagstöd/villkor/överklagande -->
					<camunda:inputParameter name="description">${decisionDescription}</camunda:inputParameter>
					<camunda:inputParameter name="createdBy">SYSTEM</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_Outcome_AutoGodkann</bpmn:incoming>
			<bpmn:incoming>Flow_Manuell_Godkann</bpmn:incoming>
			<bpmn:outgoing>Flow_SkapaBeslut_SattStatus</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_SkapaBeslut_SattStatus" sourceRef="SkapaBeslut" targetRef="SattStatusGodkand" />

		<bpmn:serviceTask id="SattStatusGodkand" name="Sätt status: beslut taget" camunda:type="external" camunda:topic="rtj-update-errand">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="status">DECIDED</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_SkapaBeslut_SattStatus</bpmn:incoming>
			<bpmn:outgoing>Flow_SattStatus_MailaBeslut</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_SattStatus_MailaBeslut" sourceRef="SattStatusGodkand" targetRef="MailaBeslut" />

		<bpmn:serviceTask id="MailaBeslut" name="Maila beslut till berörd" camunda:type="external" camunda:topic="send-email">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="emailAddress">${applicantEmail}</camunda:inputParameter>
					<camunda:inputParameter name="subject">Beslut i ditt ärende om egensotning</camunda:inputParameter>
					<camunda:inputParameter name="message">Hej! Ett beslut i ditt ärende om egensotning finns nu att hämta på Mina sidor. Logga in på Mina sidor för att läsa och ladda ner beslutet i sin helhet. Hälsningar, Räddningstjänsten Medelpad.</camunda:inputParameter>
					<camunda:inputParameter name="senderName">Räddningstjänsten Medelpad</camunda:inputParameter>
					<camunda:inputParameter name="senderAddress">noreply@sundsvall.se</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_SattStatus_MailaBeslut</bpmn:incoming>
			<bpmn:outgoing>Flow_MailaBeslut_BeslutTaget</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_MailaBeslut_BeslutTaget" sourceRef="MailaBeslut" targetRef="BeslutTaget" />

		<bpmn:endEvent id="BeslutTaget" name="Ansökan godkänns">
			<bpmn:incoming>Flow_MailaBeslut_BeslutTaget</bpmn:incoming>
		</bpmn:endEvent>

		<!-- ============================================================
		     KOMPLETTERING (bilaga saknas) — set status, email, wait for the
		     applicant to supplement, then RE-RUN the checks.
		     ============================================================ -->
		<bpmn:serviceTask id="SattStatusAwaitingSupplementation" name="Sätt status: inväntar komplettering" camunda:type="external" camunda:topic="rtj-update-errand">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="status">AWAITING_SUPPLEMENTATION</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_Outcome_Komplettering</bpmn:incoming>
			<bpmn:outgoing>Flow_AwaitingStatus_BegarKomplettering</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_AwaitingStatus_BegarKomplettering" sourceRef="SattStatusAwaitingSupplementation" targetRef="BegarKomplettering" />

		<bpmn:serviceTask id="BegarKomplettering" name="Kontakta berörd, begär komplettering" camunda:type="external" camunda:topic="send-email">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="emailAddress">${applicantEmail}</camunda:inputParameter>
					<camunda:inputParameter name="subject">Komplettering behövs för din ansökan om egensotning</camunda:inputParameter>
					<camunda:inputParameter name="message">Hej, vi behöver komplettera din ansökan om egensotning (t.ex. en bilaga eller uppgifter om sotningsobjekt). Vänligen logga in på Mina sidor och komplettera.</camunda:inputParameter>
					<camunda:inputParameter name="senderName">Räddningstjänsten Medelpad</camunda:inputParameter>
					<camunda:inputParameter name="senderAddress">noreply@sundsvall.se</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_AwaitingStatus_BegarKomplettering</bpmn:incoming>
			<bpmn:outgoing>Flow_BegarKomplettering_Vanta</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_BegarKomplettering_Vanta" sourceRef="BegarKomplettering" targetRef="KompletteringMottagen" />

		<!-- Pauses until POST /process-messages correlates "komplettering-received".
		     The applicant has added the bilaga; loop back to re-verify. -->
		<bpmn:intermediateCatchEvent id="KompletteringMottagen" name="Komplettering mottagen">
			<bpmn:incoming>Flow_BegarKomplettering_Vanta</bpmn:incoming>
			<bpmn:outgoing>Flow_Komplettering_ReVerifiera</bpmn:outgoing>
			<bpmn:messageEventDefinition messageRef="Message_KompletteringMottagen" />
		</bpmn:intermediateCatchEvent>
		<bpmn:sequenceFlow id="Flow_Komplettering_ReVerifiera" sourceRef="KompletteringMottagen" targetRef="VerifieraAnsokan" />

		<!-- ============================================================
		     MANUAL REVIEW — set status, wait for the handläggare to
		     approve/reject via rtj-management (manual-review-completed message).
		     ============================================================ -->
		<bpmn:serviceTask id="SattStatusManuell" name="Sätt status: manuell granskning" camunda:type="external" camunda:topic="rtj-update-errand">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="status">UNDER_MANUAL_REVIEW</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_Outcome_Manuell</bpmn:incoming>
			<bpmn:outgoing>Flow_SattStatusManuell_Vanta</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_SattStatusManuell_Vanta" sourceRef="SattStatusManuell" targetRef="ManuellGranskning" />

		<!-- Pauses until POST /process-messages correlates "manual-review-completed"
		     with manuelltGodkand=true|false (the handläggare's decision in the UI). -->
		<bpmn:intermediateCatchEvent id="ManuellGranskning" name="Manuell granskning klar">
			<bpmn:incoming>Flow_SattStatusManuell_Vanta</bpmn:incoming>
			<bpmn:outgoing>Flow_ManuellGranskning_Gateway</bpmn:outgoing>
			<bpmn:messageEventDefinition messageRef="Message_ManualReviewCompleted" />
		</bpmn:intermediateCatchEvent>
		<bpmn:sequenceFlow id="Flow_ManuellGranskning_Gateway" sourceRef="ManuellGranskning" targetRef="Gateway_Manuell" />

		<bpmn:exclusiveGateway id="Gateway_Manuell" name="Handläggarens åtgärd?" default="Flow_Manuell_Avslag">
			<bpmn:incoming>Flow_ManuellGranskning_Gateway</bpmn:incoming>
			<bpmn:outgoing>Flow_Manuell_Komplettering</bpmn:outgoing>
			<bpmn:outgoing>Flow_Manuell_Godkann</bpmn:outgoing>
			<bpmn:outgoing>Flow_Manuell_Avslag</bpmn:outgoing>
		</bpmn:exclusiveGateway>

		<!-- Handläggaren begär komplettering ("kräver komplettering") i stället för att besluta:
		     manual-review-completed korreleras med manuellAtgard='KOMPLETTERING' (+ kompletteringMessage
		     som mejlas till sökanden). Sätter status AWAITING_SUPPLEMENTATION, mejlar handläggarens
		     fritext och inväntar "komplettering-received", varefter ärendet omverifieras (samma
		     re-verifierings-loop som den automatiska kompletteringsgrenen). -->
		<bpmn:sequenceFlow id="Flow_Manuell_Komplettering" sourceRef="Gateway_Manuell" targetRef="SattStatusKompletteringManuell">
			<bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${manuellAtgard == 'KOMPLETTERING'}</bpmn:conditionExpression>
		</bpmn:sequenceFlow>
		<bpmn:sequenceFlow id="Flow_Manuell_Godkann" sourceRef="Gateway_Manuell" targetRef="SkapaBeslut">
			<bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${manuelltGodkand == true}</bpmn:conditionExpression>
		</bpmn:sequenceFlow>
		<bpmn:sequenceFlow id="Flow_Manuell_Avslag" sourceRef="Gateway_Manuell" targetRef="SkapaAvslag" />

		<bpmn:serviceTask id="SattStatusKompletteringManuell" name="Sätt status: inväntar komplettering" camunda:type="external" camunda:topic="rtj-update-errand">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="status">AWAITING_SUPPLEMENTATION</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_Manuell_Komplettering</bpmn:incoming>
			<bpmn:outgoing>Flow_KomplManuell_Mail</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_KomplManuell_Mail" sourceRef="SattStatusKompletteringManuell" targetRef="MailaKompletteringManuell" />

		<bpmn:serviceTask id="MailaKompletteringManuell" name="Maila handläggarens kompletteringsbegäran" camunda:type="external" camunda:topic="send-email">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="emailAddress">${applicantEmail}</camunda:inputParameter>
					<camunda:inputParameter name="subject">Komplettering behövs för din ansökan om egensotning</camunda:inputParameter>
					<camunda:inputParameter name="message">${kompletteringMessage}</camunda:inputParameter>
					<camunda:inputParameter name="senderName">Räddningstjänsten Medelpad</camunda:inputParameter>
					<camunda:inputParameter name="senderAddress">noreply@sundsvall.se</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_KomplManuell_Mail</bpmn:incoming>
			<bpmn:outgoing>Flow_KomplManuell_Vanta</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_KomplManuell_Vanta" sourceRef="MailaKompletteringManuell" targetRef="KompletteringMottagenManuell" />

		<bpmn:intermediateCatchEvent id="KompletteringMottagenManuell" name="Komplettering mottagen">
			<bpmn:incoming>Flow_KomplManuell_Vanta</bpmn:incoming>
			<bpmn:outgoing>Flow_KomplManuell_ReVerifiera</bpmn:outgoing>
			<bpmn:messageEventDefinition messageRef="Message_KompletteringMottagen" />
		</bpmn:intermediateCatchEvent>
		<bpmn:sequenceFlow id="Flow_KomplManuell_ReVerifiera" sourceRef="KompletteringMottagenManuell" targetRef="VerifieraAnsokan" />

		<!-- REJECT PATH — create decision, set status (REJECTED), THEN email, end.
		     Samma princip som approve: status före mail. -->
		<bpmn:serviceTask id="SkapaAvslag" name="Skapa beslut (avslag)" camunda:type="external" camunda:topic="rtj-add-errand-decision">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="decisionType">REJECTION</camunda:inputParameter>
					<camunda:inputParameter name="value">REJECTED</camunda:inputParameter>
					<camunda:inputParameter name="description">Ansökan om egensotning avslagen efter manuell granskning. Beslut enligt 3 kap. 4 § lagen (2003:778) om skydd mot olyckor (LSO). Beslutet kan överklagas skriftligt till Länsstyrelsen i Västernorrlands län inom tre (3) veckor från delgivning; överklagandet skickas till Medelpads Räddningstjänstförbund.</camunda:inputParameter>
					<camunda:inputParameter name="createdBy">SYSTEM</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_Manuell_Avslag</bpmn:incoming>
			<bpmn:outgoing>Flow_SkapaAvslag_SattStatus</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_SkapaAvslag_SattStatus" sourceRef="SkapaAvslag" targetRef="SattStatusAvslag" />

		<bpmn:serviceTask id="SattStatusAvslag" name="Sätt status: avslag" camunda:type="external" camunda:topic="rtj-update-errand">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="status">REJECTED</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_SkapaAvslag_SattStatus</bpmn:incoming>
			<bpmn:outgoing>Flow_SattStatus_MailaAvslag</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_SattStatus_MailaAvslag" sourceRef="SattStatusAvslag" targetRef="MailaAvslag" />

		<bpmn:serviceTask id="MailaAvslag" name="Maila avslag till berörd" camunda:type="external" camunda:topic="send-email">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="emailAddress">${applicantEmail}</camunda:inputParameter>
					<camunda:inputParameter name="subject">Beslut i ditt ärende om egensotning</camunda:inputParameter>
					<camunda:inputParameter name="message">Hej! Ett beslut i ditt ärende om egensotning finns nu att hämta på Mina sidor. Logga in på Mina sidor för att läsa och ladda ner beslutet i sin helhet. Hälsningar, Räddningstjänsten Medelpad.</camunda:inputParameter>
					<camunda:inputParameter name="senderName">Räddningstjänsten Medelpad</camunda:inputParameter>
					<camunda:inputParameter name="senderAddress">noreply@sundsvall.se</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_SattStatus_MailaAvslag</bpmn:incoming>
			<bpmn:outgoing>Flow_MailaAvslag_Avslag</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_MailaAvslag_Avslag" sourceRef="MailaAvslag" targetRef="Avslag" />

		<bpmn:endEvent id="Avslag" name="Avslag">
			<bpmn:incoming>Flow_MailaAvslag_Avslag</bpmn:incoming>
		</bpmn:endEvent>

	</bpmn:process>

	<!-- ============================================================
	     DIAGRAM (DI) — row 1: verify + approve (skapa → status → mail);
	     row 2: komplettering loop; row 3: manual review + reject (skapa →
	     status → mail). Layout is illustrative; re-layout in the modeler if needed.
	     ============================================================ -->
	<bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="egensotning-process">
      <bpmndi:BPMNShape id="AnsokanMottagen_di" bpmnElement="AnsokanMottagen"><dc:Bounds x="152" y="102" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="VerifieraAnsokan_di" bpmnElement="VerifieraAnsokan"><dc:Bounds x="240" y="80" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Outcome_di" bpmnElement="Gateway_Outcome" isMarkerVisible="true"><dc:Bounds x="420" y="95" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ValideraDokument_di" bpmnElement="ValideraDokument"><dc:Bounds x="530" y="80" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_DocumentValidation_di" bpmnElement="Gateway_DocumentValidation" isMarkerVisible="true"><dc:Bounds x="710" y="95" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SkapaBeslut_di" bpmnElement="SkapaBeslut"><dc:Bounds x="830" y="80" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SattStatusGodkand_di" bpmnElement="SattStatusGodkand"><dc:Bounds x="1010" y="80" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="MailaBeslut_di" bpmnElement="MailaBeslut"><dc:Bounds x="1190" y="80" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BeslutTaget_di" bpmnElement="BeslutTaget"><dc:Bounds x="1370" y="102" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SattStatusAwaitingSupplementation_di" bpmnElement="SattStatusAwaitingSupplementation"><dc:Bounds x="380" y="220" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BegarKomplettering_di" bpmnElement="BegarKomplettering"><dc:Bounds x="560" y="220" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="KompletteringMottagen_di" bpmnElement="KompletteringMottagen"><dc:Bounds x="712" y="242" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SattStatusManuell_di" bpmnElement="SattStatusManuell"><dc:Bounds x="380" y="360" width="120" height="80" /></bpmndi:BPMNShape>
