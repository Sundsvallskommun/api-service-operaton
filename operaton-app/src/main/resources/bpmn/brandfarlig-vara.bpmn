<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
	xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
	xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
	xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
	xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	id="Definitions_BrandfarligVara"
	targetNamespace="http://bpmn.io/schema/bpmn">

	<!-- Message declarations — correlated via POST .../errands/{errandId}/process-messages -->
	<bpmn:message id="Message_RemissvarMottaget" name="remissvar-received" />
	<bpmn:message id="Message_KompletteringMottagen" name="komplettering-received" />
	<bpmn:message id="Message_HandlaggningKlar" name="handlaggning-klar" />
	<bpmn:message id="Message_InspektionGenomford" name="inspektion-genomford" />
	<bpmn:message id="Message_AterkallaMottaget" name="aterkalla-received" />

	<!--
		Tillståndsprocess för brandfarlig vara enligt LBE (process map Bilaga B s. 29).
		Till skillnad från egensotning auto-godkänns ALDRIG ett LBE-tillstånd: verify-steget gör en
		fullständighetskontroll och routar till komplettering eller manuell handläggning. Handläggaren
		avgör sedan beslut (bevilja / tillsyn-avsyning / avslag) via message-correlation.

		v1-omfattning (de fem statusar som finns i BrandfarligVaraModuleConfig): REGISTERED →
		AWAITING_SUPPLEMENTATION / INSPECTION_SCHEDULED / DECIDED / REJECTED. Remiss/samråd (14§ FBE),
		automatiskt vägval befintlig/ny anläggning, föreläggande/förbud och återkallande (20§) är v2.
	-->
	<bpmn:process id="brandfarlig-vara-process" name="Hantera ansökan om tillstånd för brandfarlig vara" isExecutable="true" camunda:historyTimeToLive="P30D">

		<!-- ============================================================
		     START → remiss/samråd (14§ FBE) → automated completeness check
		     ============================================================ -->
		<bpmn:startEvent id="AnsokanMottagen" name="Ansökan mottagen">
			<bpmn:outgoing>Flow_Start_SkickaRemiss</bpmn:outgoing>
		</bpmn:startEvent>
		<bpmn:sequenceFlow id="Flow_Start_SkickaRemiss" sourceRef="AnsokanMottagen" targetRef="SkickaRemiss" />

		<!-- Skicka remiss/samråd till miljökontoret inför tillståndsprövningen. -->
		<bpmn:serviceTask id="SkickaRemiss" name="Skicka remiss (samråd)" camunda:type="external" camunda:topic="rtj-create-remiss">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="instans">MILJOKONTOR</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_Start_SkickaRemiss</bpmn:incoming>
			<bpmn:outgoing>Flow_SkickaRemiss_SattStatusRemiss</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_SkickaRemiss_SattStatusRemiss" sourceRef="SkickaRemiss" targetRef="SattStatusRemiss" />

		<bpmn:serviceTask id="SattStatusRemiss" name="Sätt status: inväntar remissvar" camunda:type="external" camunda:topic="rtj-update-errand">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="status">AWAITING_CONSULTATION</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_SkickaRemiss_SattStatusRemiss</bpmn:incoming>
			<bpmn:outgoing>Flow_SattStatusRemiss_Vanta</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_SattStatusRemiss_Vanta" sourceRef="SattStatusRemiss" targetRef="RemissvarMottaget" />

		<!-- Pauses until POST /process-messages correlates "remissvar-received"; then verify. -->
		<bpmn:intermediateCatchEvent id="RemissvarMottaget" name="Remissvar mottaget">
			<bpmn:incoming>Flow_SattStatusRemiss_Vanta</bpmn:incoming>
			<bpmn:outgoing>Flow_Remissvar_Verifiera</bpmn:outgoing>
			<bpmn:messageEventDefinition messageRef="Message_RemissvarMottaget" />
		</bpmn:intermediateCatchEvent>
		<bpmn:sequenceFlow id="Flow_Remissvar_Verifiera" sourceRef="RemissvarMottaget" targetRef="VerifieraAnsokan" />

		<!-- Runs the brandfarlig-vara completeness check in rtj-management (hanteringsplats, minst en
		     brandfarlig vara, minst en bilaga) and writes outcome + decisionDescription to process
		     variables. Re-entered after a komplettering. -->
		<bpmn:serviceTask id="VerifieraAnsokan" name="Verifiera ansökan" camunda:type="external" camunda:topic="rtj-verify-brandfarlig-vara">
			<bpmn:incoming>Flow_Remissvar_Verifiera</bpmn:incoming>
			<bpmn:incoming>Flow_Kompl_ReVerifiera</bpmn:incoming>
			<bpmn:outgoing>Flow_Verifiera_Gateway</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_Verifiera_Gateway" sourceRef="VerifieraAnsokan" targetRef="Gateway_Outcome" />

		<bpmn:exclusiveGateway id="Gateway_Outcome" name="Utfall?" default="Flow_Outcome_Manuell">
			<bpmn:incoming>Flow_Verifiera_Gateway</bpmn:incoming>
			<bpmn:outgoing>Flow_Outcome_Komplettering</bpmn:outgoing>
			<bpmn:outgoing>Flow_Outcome_Manuell</bpmn:outgoing>
		</bpmn:exclusiveGateway>
		<bpmn:sequenceFlow id="Flow_Outcome_Komplettering" sourceRef="Gateway_Outcome" targetRef="SattStatusAwaitingSupplementation">
			<bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${outcome == 'NEEDS_SUPPLEMENT'}</bpmn:conditionExpression>
		</bpmn:sequenceFlow>
		<bpmn:sequenceFlow id="Flow_Outcome_Manuell" sourceRef="Gateway_Outcome" targetRef="SkickaMottagningsbevis" />

		<!-- ============================================================
		     KOMPLETTERING — set status, email, wait for the applicant to
		     supplement, then RE-RUN the completeness check.
		     ============================================================ -->
		<bpmn:serviceTask id="SattStatusAwaitingSupplementation" name="Sätt status: inväntar komplettering" camunda:type="external" camunda:topic="rtj-update-errand">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="status">AWAITING_SUPPLEMENTATION</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_Outcome_Komplettering</bpmn:incoming>
			<bpmn:outgoing>Flow_AwaitingStatus_BegarKomplettering</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_AwaitingStatus_BegarKomplettering" sourceRef="SattStatusAwaitingSupplementation" targetRef="BegarKomplettering" />

		<bpmn:serviceTask id="BegarKomplettering" name="Begär komplettering" camunda:type="external" camunda:topic="send-email">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="emailAddress">${applicantEmail}</camunda:inputParameter>
					<camunda:inputParameter name="subject">Komplettering behövs – ansökan om tillstånd för brandfarlig vara</camunda:inputParameter>
					<camunda:inputParameter name="message">Hej, din ansökan om tillstånd för brandfarlig vara behöver kompletteras (t.ex. riskutredning enligt 7 § LBE, situationsplan, uppgifter om hanteringsplats eller om de brandfarliga varorna). Vänligen logga in på Mina sidor och komplettera ansökan.</camunda:inputParameter>
					<camunda:inputParameter name="senderName">Räddningstjänsten Medelpad</camunda:inputParameter>
					<camunda:inputParameter name="senderAddress">noreply@sundsvall.se</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_AwaitingStatus_BegarKomplettering</bpmn:incoming>
			<bpmn:outgoing>Flow_BegarKomplettering_Vanta</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_BegarKomplettering_Vanta" sourceRef="BegarKomplettering" targetRef="KompletteringMottagen" />

		<!-- Pauses until POST /process-messages correlates "komplettering-received"; loop back to re-verify. -->
		<bpmn:intermediateCatchEvent id="KompletteringMottagen" name="Komplettering mottagen">
			<bpmn:incoming>Flow_BegarKomplettering_Vanta</bpmn:incoming>
			<bpmn:outgoing>Flow_Kompl_ReVerifiera</bpmn:outgoing>
			<bpmn:messageEventDefinition messageRef="Message_KompletteringMottagen" />
		</bpmn:intermediateCatchEvent>
		<bpmn:sequenceFlow id="Flow_Kompl_ReVerifiera" sourceRef="KompletteringMottagen" targetRef="VerifieraAnsokan" />

		<!-- ============================================================
		     MANUELL HANDLÄGGNING — send mottagningsbevis, wait for the handläggare
		     to decide (handlaggning-klar med beslut = APPROVE | INSPECTION | REJECT).
		     ============================================================ -->
		<bpmn:serviceTask id="SkickaMottagningsbevis" name="Skicka mottagningsbevis" camunda:type="external" camunda:topic="send-email">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="emailAddress">${applicantEmail}</camunda:inputParameter>
					<camunda:inputParameter name="subject">Mottagningsbevis – ansökan om tillstånd för brandfarlig vara</camunda:inputParameter>
					<camunda:inputParameter name="message">Hej, din ansökan om tillstånd för brandfarlig vara har tagits emot och bedömts fullständig. Beslut fattas normalt inom tre (3) månader från det att en fullständig ansökan inkommit (17 § förordningen [2010:1075] om brandfarliga och explosiva varor). Du kan följa ärendet på Mina sidor.</camunda:inputParameter>
					<camunda:inputParameter name="senderName">Räddningstjänsten Medelpad</camunda:inputParameter>
					<camunda:inputParameter name="senderAddress">noreply@sundsvall.se</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_Outcome_Manuell</bpmn:incoming>
			<bpmn:outgoing>Flow_Mottag_Handlagg</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_Mottag_Handlagg" sourceRef="SkickaMottagningsbevis" targetRef="ManuellHandlaggning" />

		<!-- Pauses until POST /process-messages correlates "handlaggning-klar" with
		     beslut = APPROVE | INSPECTION | REJECT (the handläggare's decision in the UI). -->
		<bpmn:intermediateCatchEvent id="ManuellHandlaggning" name="Intern handläggning klar">
			<bpmn:incoming>Flow_Mottag_Handlagg</bpmn:incoming>
			<bpmn:outgoing>Flow_Handlagg_Gateway</bpmn:outgoing>
			<bpmn:messageEventDefinition messageRef="Message_HandlaggningKlar" />
		</bpmn:intermediateCatchEvent>
		<bpmn:sequenceFlow id="Flow_Handlagg_Gateway" sourceRef="ManuellHandlaggning" targetRef="Gateway_Beslut" />

		<bpmn:exclusiveGateway id="Gateway_Beslut" name="Beslut?" default="Flow_Beslut_Avslag">
			<bpmn:incoming>Flow_Handlagg_Gateway</bpmn:incoming>
			<bpmn:outgoing>Flow_Beslut_Tillstand</bpmn:outgoing>
			<bpmn:outgoing>Flow_Beslut_Inspektion</bpmn:outgoing>
			<bpmn:outgoing>Flow_Beslut_Avslag</bpmn:outgoing>
		</bpmn:exclusiveGateway>
		<bpmn:sequenceFlow id="Flow_Beslut_Tillstand" sourceRef="Gateway_Beslut" targetRef="Tillstandsbeslut">
			<bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${beslut == 'APPROVE'}</bpmn:conditionExpression>
		</bpmn:sequenceFlow>
		<bpmn:sequenceFlow id="Flow_Beslut_Inspektion" sourceRef="Gateway_Beslut" targetRef="SattStatusInspektion">
			<bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${beslut == 'INSPECTION'}</bpmn:conditionExpression>
		</bpmn:sequenceFlow>
		<bpmn:sequenceFlow id="Flow_Beslut_Avslag" sourceRef="Gateway_Beslut" targetRef="SkapaAvslag" />

		<!-- ============================================================
		     TILLSYN/AVSYNING (platsbesök) — befintlig anläggning → tillsyn 21§ LBE,
		     ny anläggning → avsyning 16§ FBE. v1 modellerar bägge som ett gemensamt
		     vänteläge: sätt status, vänta på att besöket genomförts (inspektion-genomford
		     med godkand = true|false), routa till tillstånd eller avslag.
		     ============================================================ -->
		<bpmn:serviceTask id="SattStatusInspektion" name="Sätt status: platsbesök planerat" camunda:type="external" camunda:topic="rtj-update-errand">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="status">INSPECTION_SCHEDULED</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_Beslut_Inspektion</bpmn:incoming>
			<bpmn:outgoing>Flow_Inspektion_Vanta</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_Inspektion_Vanta" sourceRef="SattStatusInspektion" targetRef="InspektionGenomford" />

		<bpmn:intermediateCatchEvent id="InspektionGenomford" name="Platsbesök genomfört">
			<bpmn:incoming>Flow_Inspektion_Vanta</bpmn:incoming>
			<bpmn:outgoing>Flow_Inspektion_Gateway</bpmn:outgoing>
			<bpmn:messageEventDefinition messageRef="Message_InspektionGenomford" />
		</bpmn:intermediateCatchEvent>
		<bpmn:sequenceFlow id="Flow_Inspektion_Gateway" sourceRef="InspektionGenomford" targetRef="Gateway_Inspektion" />

		<bpmn:exclusiveGateway id="Gateway_Inspektion" name="Godkänt?" default="Flow_Inspektion_Avslag">
			<bpmn:incoming>Flow_Inspektion_Gateway</bpmn:incoming>
			<bpmn:outgoing>Flow_Inspektion_Tillstand</bpmn:outgoing>
			<bpmn:outgoing>Flow_Inspektion_Avslag</bpmn:outgoing>
		</bpmn:exclusiveGateway>
		<bpmn:sequenceFlow id="Flow_Inspektion_Tillstand" sourceRef="Gateway_Inspektion" targetRef="Tillstandsbeslut">
			<bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${godkand == true}</bpmn:conditionExpression>
		</bpmn:sequenceFlow>
		<bpmn:sequenceFlow id="Flow_Inspektion_Avslag" sourceRef="Gateway_Inspektion" targetRef="SkapaAvslag" />

		<!-- ============================================================
		     TILLSTÅNDSBESLUT (delat) — skapa beslut, maila, sätt status DECIDED, slut.
		     ============================================================ -->
		<bpmn:serviceTask id="Tillstandsbeslut" name="Skapa beslut (tillstånd)" camunda:type="external" camunda:topic="rtj-add-errand-decision">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="decisionType">APPROVAL</camunda:inputParameter>
					<camunda:inputParameter name="value">APPROVED</camunda:inputParameter>
					<!-- Formell beslutstext (omfattning + lagstöd + villkor + tillståndstid + överklagande)
					     genereras av verifieringssteget och bärs som processvariabel. -->
					<camunda:inputParameter name="description">${decisionDescription}</camunda:inputParameter>
					<camunda:inputParameter name="createdBy">SYSTEM</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_Beslut_Tillstand</bpmn:incoming>
			<bpmn:incoming>Flow_Inspektion_Tillstand</bpmn:incoming>
			<bpmn:outgoing>Flow_Tillstand_Mail</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_Tillstand_Mail" sourceRef="Tillstandsbeslut" targetRef="UtfardaTillstand" />

		<!-- Utfärda tillståndet (permit) med giltighetstid (5 år → fasta datum) — beräknas server-side. -->
		<bpmn:serviceTask id="UtfardaTillstand" name="Utfärda tillstånd" camunda:type="external" camunda:topic="rtj-create-permit">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="permitType">BRANDFARLIG_VARA</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_Tillstand_Mail</bpmn:incoming>
			<bpmn:outgoing>Flow_Permit_Mail</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_Permit_Mail" sourceRef="UtfardaTillstand" targetRef="MailaBeslut" />

		<bpmn:serviceTask id="MailaBeslut" name="Maila beslut till sökande" camunda:type="external" camunda:topic="send-email">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="emailAddress">${applicantEmail}</camunda:inputParameter>
					<camunda:inputParameter name="subject">Beslut: Tillstånd för brandfarlig vara beviljat</camunda:inputParameter>
					<camunda:inputParameter name="message">Hej, din ansökan om tillstånd för hantering av brandfarlig vara har beviljats med stöd av 16–19 §§ lagen (2010:1011) om brandfarliga och explosiva varor (LBE). Tillståndets omfattning, villkor och giltighetstid framgår av beslutet på Mina sidor. Beslutet kan överklagas skriftligt till Länsstyrelsen i Västernorrlands län inom tre (3) veckor från delgivning; överklagandet skickas till Medelpads Räddningstjänstförbund.</camunda:inputParameter>
					<camunda:inputParameter name="senderName">Räddningstjänsten Medelpad</camunda:inputParameter>
					<camunda:inputParameter name="senderAddress">noreply@sundsvall.se</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_Permit_Mail</bpmn:incoming>
			<bpmn:outgoing>Flow_Mail_Status</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_Mail_Status" sourceRef="MailaBeslut" targetRef="SattStatusBeviljat" />

		<bpmn:serviceTask id="SattStatusBeviljat" name="Sätt status: beslut taget" camunda:type="external" camunda:topic="rtj-update-errand">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="status">DECIDED</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_Mail_Status</bpmn:incoming>
			<bpmn:outgoing>Flow_Status_End</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_Status_End" sourceRef="SattStatusBeviljat" targetRef="BeslutTaget" />

		<bpmn:endEvent id="BeslutTaget" name="Tillstånd beviljat">
			<bpmn:incoming>Flow_Status_End</bpmn:incoming>
		</bpmn:endEvent>

		<!-- ============================================================
		     AVSLAG/FÖRBUD (delat) — skapa beslut, maila, sätt status REJECTED, slut.
		     ============================================================ -->
		<bpmn:serviceTask id="SkapaAvslag" name="Skapa beslut (avslag)" camunda:type="external" camunda:topic="rtj-add-errand-decision">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="decisionType">REJECTION</camunda:inputParameter>
					<camunda:inputParameter name="value">REJECTED</camunda:inputParameter>
					<camunda:inputParameter name="description">Ansökan om tillstånd för brandfarlig vara avslås. Beslut enligt 16–19 §§ lagen (2010:1011) om brandfarliga och explosiva varor (LBE). Beslutet kan överklagas skriftligt till Länsstyrelsen i Västernorrlands län inom tre (3) veckor från delgivning; överklagandet skickas till Medelpads Räddningstjänstförbund.</camunda:inputParameter>
					<camunda:inputParameter name="createdBy">SYSTEM</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_Beslut_Avslag</bpmn:incoming>
			<bpmn:incoming>Flow_Inspektion_Avslag</bpmn:incoming>
			<bpmn:outgoing>Flow_Avslag_Mail</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_Avslag_Mail" sourceRef="SkapaAvslag" targetRef="MailaAvslag" />

		<bpmn:serviceTask id="MailaAvslag" name="Maila avslag till sökande" camunda:type="external" camunda:topic="send-email">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="emailAddress">${applicantEmail}</camunda:inputParameter>
					<camunda:inputParameter name="subject">Beslut: Avslag på ansökan om tillstånd för brandfarlig vara</camunda:inputParameter>
					<camunda:inputParameter name="message">Hej, efter prövning har din ansökan om tillstånd för hantering av brandfarlig vara avslagits. Beslutet är fattat med stöd av 16–19 §§ lagen (2010:1011) om brandfarliga och explosiva varor (LBE). Skäl och fullständigt beslut finns på Mina sidor. Beslutet kan överklagas skriftligt till Länsstyrelsen i Västernorrlands län inom tre (3) veckor från delgivning; överklagandet skickas till Medelpads Räddningstjänstförbund.</camunda:inputParameter>
					<camunda:inputParameter name="senderName">Räddningstjänsten Medelpad</camunda:inputParameter>
					<camunda:inputParameter name="senderAddress">noreply@sundsvall.se</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_Avslag_Mail</bpmn:incoming>
			<bpmn:outgoing>Flow_AvslagMail_Status</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_AvslagMail_Status" sourceRef="MailaAvslag" targetRef="SattStatusAvslag" />

		<bpmn:serviceTask id="SattStatusAvslag" name="Sätt status: avslag" camunda:type="external" camunda:topic="rtj-update-errand">
			<bpmn:extensionElements>
				<camunda:inputOutput>
					<camunda:inputParameter name="status">REJECTED</camunda:inputParameter>
				</camunda:inputOutput>
			</bpmn:extensionElements>
			<bpmn:incoming>Flow_AvslagMail_Status</bpmn:incoming>
			<bpmn:outgoing>Flow_AvslagStatus_End</bpmn:outgoing>
		</bpmn:serviceTask>
		<bpmn:sequenceFlow id="Flow_AvslagStatus_End" sourceRef="SattStatusAvslag" targetRef="Avslag" />

		<bpmn:endEvent id="Avslag" name="Avslag">
			<bpmn:incoming>Flow_AvslagStatus_End</bpmn:incoming>
		</bpmn:endEvent>

		<!-- ============================================================
		     ÅTERKALLANDE (20§ LBE) — interrupting event subprocess. Triggered by the
		     "aterkalla-received" message: revoke all active permits, set status REVOKED, end.
		     ============================================================ -->
		<bpmn:subProcess id="AterkallaSubprocess" name="Återkallande av tillstånd (20§ LBE)" triggeredByEvent="true">
			<bpmn:startEvent id="AterkallaMottaget" name="Återkallande begärt" isInterrupting="true">
				<bpmn:outgoing>Flow_Aterkalla_Revoke</bpmn:outgoing>
				<bpmn:messageEventDefinition messageRef="Message_AterkallaMottaget" />
			</bpmn:startEvent>
			<bpmn:sequenceFlow id="Flow_Aterkalla_Revoke" sourceRef="AterkallaMottaget" targetRef="AterkallaPermit" />

			<bpmn:serviceTask id="AterkallaPermit" name="Återkalla tillstånd" camunda:type="external" camunda:topic="rtj-revoke-permit">
				<bpmn:incoming>Flow_Aterkalla_Revoke</bpmn:incoming>
				<bpmn:outgoing>Flow_Aterkalla_SattStatus</bpmn:outgoing>
			</bpmn:serviceTask>
			<bpmn:sequenceFlow id="Flow_Aterkalla_SattStatus" sourceRef="AterkallaPermit" targetRef="SattStatusAterkallat" />

			<bpmn:serviceTask id="SattStatusAterkallat" name="Sätt status: återkallat" camunda:type="external" camunda:topic="rtj-update-errand">
				<bpmn:extensionElements>
					<camunda:inputOutput>
						<camunda:inputParameter name="status">REVOKED</camunda:inputParameter>
					</camunda:inputOutput>
				</bpmn:extensionElements>
				<bpmn:incoming>Flow_Aterkalla_SattStatus</bpmn:incoming>
				<bpmn:outgoing>Flow_Aterkalla_End</bpmn:outgoing>
			</bpmn:serviceTask>
			<bpmn:sequenceFlow id="Flow_Aterkalla_End" sourceRef="SattStatusAterkallat" targetRef="Aterkallat" />

			<bpmn:endEvent id="Aterkallat" name="Tillstånd återkallat">
				<bpmn:incoming>Flow_Aterkalla_End</bpmn:incoming>
			</bpmn:endEvent>
		</bpmn:subProcess>

	</bpmn:process>

